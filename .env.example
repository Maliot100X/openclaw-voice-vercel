# Cloudflared tunnel URL pointing to the Ubuntu relay server.
# This changes every time the tunnel restarts (quick tunnels use random subdomains).
# Update this value on Vercel when you restart the tunnel.
NEXT_PUBLIC_RELAY_URL=wss://leave-recorded-vernon-restructuring.trycloudflare.com

# Deepgram API key -- only needed on the relay server (relay_server.py),
# NOT on Vercel. The key never reaches the browser.
# DEEPGRAM_API_KEY=your_key_here
